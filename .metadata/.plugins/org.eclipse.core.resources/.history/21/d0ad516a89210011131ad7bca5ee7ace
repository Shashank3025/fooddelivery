package com.fooddelivery.order.entity;

@Entity
@Table(name="order_items")
@Data
@NoArgsConstructor
@AllArgsConstructor
public class OrderItem {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    private Long menuItemId;

    private Integer quantity;

    @ManyToOne
    @JoinColumn(name="order_id")
    private Order order;
}